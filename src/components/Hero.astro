---
import { Icon } from "astro-icon/components";
import { Picture } from "astro:assets";
import img from "/src/assets/huiyang.png";
---

<section
  class="py-20 flex md:flex-row flex-col px-4 md:px-0 gap-10 md:gap-0 self-center max-w-5xl mx-auto"
>
  <div class="flex flex-col gap-6 justify-start items-start md:w-1/2">
    <h1 class="text-pblack">Hi, my name is Huiyang Wang (Wystan Wang)</h1>
    <p class="text-6xl font-bold">The world is sound.</p>
    <p>
      I’m a poet, sound artist, backend software engineer, scuba diver, exploring the
      intersections of technology and art. My interests lie in algorithmic composition, creative coding, 
      sonification, audio programming, soundscape, physical computing, poetry, posthumanism.
    </p>
    <a
      rel="noopener noreferrer"
      href="/about"
      arial-label="Work together"
      class="bg-pgreen px-5 py-3 border-1 border-black rounded-lg shadow-card hover:shadow-hover transition"
    >
      Work together
    </a>
  </div>
  <div class="md:w-1/2 object-contain flex items-center justify-end p-10 group">
    <!-- <a
      arial-label="Huiyang Wang Wikipedia"
      rel="noopener noreferrer"
      href="https://es.wikipedia.org/wiki/Joaqu%C3%ADn_Sorolla"
      target="_blank"
    > -->
      <div
        class="bg-pblue border-3 border-black rounded-2xl h-52 w-60 shadow-card group-hover:shadow-hover flex transition relative"
      >
        <div
          class="absolute -top-8 -left-12 text-5xl bg-ppink px-5 py-1 z-10 shadow-card group-hover:shadow-hover transition rounded-t-2xl border-3 border-black rounded-bl-2xl rounded-br-sm"
        >
          <Icon name="wave1" />
        </div>
        <div
          class="absolute top-16 -right-16 text-5xl bg-pyellow p-2 z-10 shadow-card group-hover:shadow-hover transition rounded-full border-3 border-black"
        >
          <Icon name="writing1" />
        </div>
        <div
          class="absolute text-nowrap flex items-center gap-4 -bottom-12 right-0 pr-4 bg-pgreen pl-1 z-10 shadow-card1 group-hover:shadow-card transition rounded-full border-3 border-black"
        >
          <Icon name="code" />
          <p>Huiyang Wang</p>
        </div>
        <div class="h-80 w-60 overflow-hidden relative -mt-30 rounded-2xl">
          <Picture
            class="object-bottom absolute bottom-0 group-hover:scale-105 transition"
            src={img}
            format="png"
            sizes="(max-width: 300px) 100vw, 600px"
            widths={[300, 600]}
            alt="Wang, photo wiki"
          />
        </div>
      </div>
      <!-- </a> -->
  </div>
</section>
